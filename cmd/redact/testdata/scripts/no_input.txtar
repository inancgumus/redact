# Empty stdin produces empty output, exits 0 (cat-like).
exec ./redact
! stdout .
! stderr .

# Explicit -h prints usage and exits 0.
exec ./redact -h
stderr 'usage: redact'
! stdout .

# Positional args are rejected.
! exec ./redact some-text
stderr 'unexpected positional args'

# Empty -string yields empty output.
exec ./redact -string ''
! stdout .
